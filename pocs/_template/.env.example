# Snowflake 연결 자격증명
# 이 파일을 .env 로 복사한 뒤 실제 값을 채운다
# .env 는 git에 커밋하지 않는다

SNOWFLAKE_ACCOUNT=         # ex) abc12345.ap-northeast-1.aws
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=            # ex) SYSADMIN
SNOWFLAKE_WAREHOUSE=       # ex) COMPUTE_WH
SNOWFLAKE_DATABASE=        # 기본 작업 대상 DB
SNOWFLAKE_SCHEMA=          # 기본 스키마 (보통 PUBLIC)
